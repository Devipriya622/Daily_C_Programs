//anagram
#include<stdio.h>
#include<string.h>
int main(){
    char str1[100];
    char str2[100];
    printf("Enter the string 1: ");
    scanf("%s",str1);
    printf("Enter string 2:");
    scanf("%s",str2);
     
     int arr[26];
     for(int i=0;i<strlen(str1);i++){
       arr[str1[i]-'a']++;
     }
     for(int i=0;i<strlen(str2);i++){
         arr[str2[i]-'a']--;
     }
     for(int i=0;i<26;i++){
         if(arr[i]!=0){
             printf("not anagram");
            return 0;
            
         }
     }
     printf("anagram");
    
}